# ─── Supabase (client-side, required for cloud sync + auth) ──────────────────
# Copy from your Supabase project: Project Settings → API → Project URL & anon key.
# Without these, the app runs in offline mode (localStorage only).
# Add the SAME 2 values to Vercel: Project → Settings → Environment Variables.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Anthropic (server-side, Vercel only) ────────────────────────────────────
# Required for AI clothing recognition + outfit suggestions + style chat.
# Set on Vercel only (NOT locally) — local dev proxies /api/* to the deployed URL.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── fal.ai (server-side, Vercel only) ───────────────────────────────────────
# Required for the realistic Avatar render (Nano Banana / Gemini Flash Image):
# renders the user wearing a wardrobe look from their selfie.
# Set on Vercel only — local dev proxies /api/* to the deployed URL.
# Get one at https://fal.ai/dashboard/keys
FAL_KEY=
# Optional — override the image model (default: fal-ai/nano-banana/edit)
# FAL_AVATAR_MODEL=fal-ai/nano-banana/edit
