# ─── Firebase (client-side, required for cloud sync) ─────────────────────────
# Copy from your Firebase project: Project settings → General → Your apps → Web app config.
# Without these, the app runs in offline mode (localStorage only).
# Add the SAME 5 values to Vercel: Project → Settings → Environment Variables.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_APP_ID=

# ─── Anthropic (server-side, Vercel only) ────────────────────────────────────
# Required for AI clothing recognition + outfit suggestions + style chat.
# Set on Vercel only (NOT locally) — local dev proxies /api/* to the deployed URL.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
